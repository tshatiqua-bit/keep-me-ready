# Supabase — get these from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Instructor Dashboard — email of the admin user who can access /admin
ADMIN_EMAIL=you@example.com

# Sentry error monitoring — create a project at sentry.io to get these.
# NEXT_PUBLIC_SENTRY_DSN is baked into the browser bundle (safe to expose).
# SENTRY_DSN is server-only. Both can be the same DSN value.
# SENTRY_ORG, SENTRY_PROJECT, and SENTRY_AUTH_TOKEN are only needed for
# source map uploads during CI builds — omit them locally.
NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://your-public-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=keep-me-ready
SENTRY_AUTH_TOKEN=your-auth-token-here
